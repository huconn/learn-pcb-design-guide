---
// Cross-section diagram of a microstrip with labeled dimensions.
interface Props {
  showDifferential?: boolean;
}
const { showDifferential = false } = Astro.props;
---
<figure class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <svg viewBox="0 0 540 220" class="w-full" role="img" aria-label="Microstrip cross-section with W, H, T, εr labeled">
    <rect x="1" y="1" width="538" height="218" fill="#fff" stroke="#e2e8f0" />
    <text x="14" y="20" font-size="11" font-family="ui-monospace, monospace" fill="#0f172a">단면 (Cross-section) — 위에서 본 PCB 옆면</text>

    <!-- air -->
    <rect x="40" y="40"  width="460" height="50" fill="#f1f5f9" />
    <text x="46" y="58" font-size="10" fill="#64748b" font-family="ui-monospace, monospace">공기 (또는 솔더마스크)</text>

    <!-- dielectric -->
    <rect x="40" y="90"  width="460" height="60" fill="#fef3c7" stroke="#fcd34d" />
    <text x="46" y="124" font-size="10" fill="#92400e" font-family="ui-monospace, monospace">유전체 (FR4 ε_r ≈ 4.2)</text>

    <!-- ground plane -->
    <rect x="40" y="150" width="460" height="20" fill="#94a3b8" stroke="#64748b" />
    <text x="46" y="164" font-size="10" fill="#fff" font-family="ui-monospace, monospace">GND plane</text>

    {!showDifferential && (
      <g>
        <!-- single trace on top of dielectric -->
        <rect x="240" y="80" width="60" height="10" fill="#f59e0b" stroke="#b45309" />
        <text x="260" y="76" font-size="10" fill="#92400e" font-family="ui-monospace, monospace">trace</text>

        <!-- W dimension -->
        <line x1="240" y1="65" x2="300" y2="65" stroke="#0ea5e9" stroke-width="1" marker-start="url(#m1)" marker-end="url(#m1)"/>
        <text x="262" y="60" font-size="11" fill="#0369a1" font-family="ui-monospace, monospace" font-weight="600">W</text>

        <!-- T dimension (right side) -->
        <line x1="310" y1="80" x2="310" y2="90" stroke="#7c3aed" stroke-width="1" marker-start="url(#m2)" marker-end="url(#m2)"/>
        <text x="316" y="89" font-size="11" fill="#5b21b6" font-family="ui-monospace, monospace" font-weight="600">T</text>
      </g>
    )}

    {showDifferential && (
      <g>
        <!-- two parallel traces -->
        <rect x="200" y="80" width="50" height="10" fill="#f59e0b" stroke="#b45309" />
        <rect x="290" y="80" width="50" height="10" fill="#f59e0b" stroke="#b45309" />
        <text x="216" y="76" font-size="10" fill="#92400e" font-family="ui-monospace, monospace">+</text>
        <text x="306" y="76" font-size="10" fill="#92400e" font-family="ui-monospace, monospace">−</text>

        <!-- W dimensions -->
        <line x1="200" y1="65" x2="250" y2="65" stroke="#0ea5e9" stroke-width="1" marker-start="url(#m1)" marker-end="url(#m1)"/>
        <text x="217" y="60" font-size="11" fill="#0369a1" font-family="ui-monospace, monospace" font-weight="600">W</text>

        <!-- S dimension -->
        <line x1="250" y1="85" x2="290" y2="85" stroke="#10b981" stroke-width="1.2" marker-start="url(#m3)" marker-end="url(#m3)"/>
        <text x="263" y="80" font-size="11" fill="#047857" font-family="ui-monospace, monospace" font-weight="600">S</text>

        <line x1="290" y1="65" x2="340" y2="65" stroke="#0ea5e9" stroke-width="1" marker-start="url(#m1)" marker-end="url(#m1)"/>
        <text x="307" y="60" font-size="11" fill="#0369a1" font-family="ui-monospace, monospace" font-weight="600">W</text>
      </g>
    )}

    <!-- H dimension (left side) -->
    <line x1="20" y1="90" x2="20" y2="150" stroke="#ef4444" stroke-width="1.2" marker-start="url(#m4)" marker-end="url(#m4)"/>
    <text x="6" y="124" font-size="11" fill="#b91c1c" font-family="ui-monospace, monospace" font-weight="600">H</text>

    <!-- legend -->
    <g font-family="ui-monospace, monospace" font-size="10" fill="#475569">
      <text x="20"  y="200">W = 트레이스 폭</text>
      <text x="135" y="200">H = 유전체 두께 (plane 까지 거리)</text>
      <text x="320" y="200">T = 동박 두께 (1 oz ≈ 1.4 mil = 35 μm)</text>
      {showDifferential && <text x="20" y="214" fill="#047857">S = 페어 사이 간격 (edge-to-edge)</text>}
    </g>

    <defs>
      <marker id="m1" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M0 5 L10 0 L10 10 z" fill="#0ea5e9"/></marker>
      <marker id="m2" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M0 5 L10 0 L10 10 z" fill="#7c3aed"/></marker>
      <marker id="m3" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M0 5 L10 0 L10 10 z" fill="#10b981"/></marker>
      <marker id="m4" viewBox="0 0 10 10" refX="5" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse"><path d="M0 5 L10 0 L10 10 z" fill="#ef4444"/></marker>
    </defs>
  </svg>
</figure>
