---
// Three termination topologies side by side with tiny circuit sketches
const topos = [
  {
    name: 'Series',
    subtitle: 'source 측 Rs = Z₀ − Z_driver',
    desc: '드라이버 직후 저항으로 source 반사 흡수. 전력 0 소비. 로드가 CMOS(고 Z)일 때 유리. 단, V_load 파형이 2·Td 동안 중간값에 머무름(플랫).',
    circuit: 'series',
  },
  {
    name: 'Parallel (DC)',
    subtitle: '로드에 Z₀ to GND',
    desc: '로드 측 저항으로 반사 흡수. 제일 깨끗한 파형. 단, DC 전류가 항상 흐름 — 전력 소모 크다. 로드가 high-Z 아닐 때 쓰기 좋다.',
    circuit: 'parallel',
  },
  {
    name: 'AC (RC)',
    subtitle: '로드에 R (=Z₀) + C 직렬 to GND',
    desc: 'DC 는 차단 · AC 성분만 흡수. parallel 의 전력 문제 해결. 클럭·버스 라인처럼 DC 성분이 적은 신호에 적합.',
    circuit: 'ac',
  },
];
---
<div class="not-prose grid gap-3 md:grid-cols-3">
  {topos.map((t) => (
    <figure class="rounded-lg border border-slate-200 bg-white p-3">
      <div class="font-mono text-xs text-indigo-700">{t.name}</div>
      <div class="font-mono text-[10px] text-slate-500 mt-0.5">{t.subtitle}</div>

      <svg viewBox="0 0 220 120" class="mt-2 w-full">
        <rect x="1" y="1" width="218" height="118" fill="#f8fafc" stroke="#e2e8f0" />

        <!-- Driver -->
        <rect x="8" y="45" width="22" height="18" fill="#0f172a" />
        <text x="10" y="58" font-size="7" fill="#fff" font-family="ui-monospace, monospace">DRV</text>

        <!-- Line -->
        <line x1="30" y1="54" x2="170" y2="54" stroke="#334155" stroke-width="1.8" />

        <!-- Receiver -->
        <rect x="170" y="45" width="22" height="18" fill="#0f172a" />
        <text x="173" y="58" font-size="7" fill="#fff" font-family="ui-monospace, monospace">RX</text>

        <!-- Termination element -->
        {t.circuit === 'series' && (
          <g>
            <rect x="34" y="50" width="18" height="8" fill="#4f46e5" stroke="#312e81" stroke-width="0.5" />
            <text x="35" y="46" font-size="7" fill="#4f46e5" font-family="ui-monospace, monospace">Rs</text>
          </g>
        )}
        {t.circuit === 'parallel' && (
          <g>
            <line x1="162" y1="54" x2="162" y2="85" stroke="#334155" stroke-width="1" />
            <rect x="156" y="78" width="12" height="14" fill="#4f46e5" stroke="#312e81" stroke-width="0.5" />
            <text x="170" y="86" font-size="7" fill="#4f46e5" font-family="ui-monospace, monospace">Z₀</text>
            <line x1="156" y1="96" x2="168" y2="96" stroke="#334155" stroke-width="1.2" />
            <line x1="158" y1="100" x2="166" y2="100" stroke="#334155" stroke-width="1" />
            <line x1="160" y1="104" x2="164" y2="104" stroke="#334155" stroke-width="1" />
          </g>
        )}
        {t.circuit === 'ac' && (
          <g>
            <line x1="162" y1="54" x2="162" y2="72" stroke="#334155" stroke-width="1" />
            <rect x="156" y="72" width="12" height="10" fill="#4f46e5" stroke="#312e81" stroke-width="0.5" />
            <text x="170" y="80" font-size="7" fill="#4f46e5" font-family="ui-monospace, monospace">R</text>
            <line x1="162" y1="82" x2="162" y2="88" stroke="#334155" stroke-width="1" />
            <line x1="154" y1="88" x2="170" y2="88" stroke="#334155" stroke-width="1.5" />
            <line x1="154" y1="92" x2="170" y2="92" stroke="#334155" stroke-width="1.5" />
            <text x="175" y="92" font-size="7" fill="#4f46e5" font-family="ui-monospace, monospace">C</text>
            <line x1="162" y1="92" x2="162" y2="100" stroke="#334155" stroke-width="1" />
            <line x1="156" y1="100" x2="168" y2="100" stroke="#334155" stroke-width="1.2" />
            <line x1="158" y1="104" x2="166" y2="104" stroke="#334155" stroke-width="1" />
          </g>
        )}
      </svg>

      <figcaption class="mt-2 text-[11px] text-slate-700 leading-relaxed">{t.desc}</figcaption>
    </figure>
  ))}
</div>
