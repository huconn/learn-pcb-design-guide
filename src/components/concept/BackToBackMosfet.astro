---
// Back-to-back N-channel MOSFETs — typical low-side BMS topology.
// Two N-channel FETs with sources tied at MID, drains pointing outward
// (B- and PACK-). Body diodes face OPPOSITE directions, so neither
// charge nor discharge can flow unless the corresponding FET is ON.
---
<figure class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <svg viewBox="0 0 680 360" class="w-full" role="img" aria-label="Back-to-back N-channel MOSFETs in a BMS — low-side topology with sources tied at MID and body diodes facing outward in opposite directions">
    <rect x="1" y="1" width="678" height="358" fill="#fff" stroke="#e2e8f0" />
    <text x="14" y="20" font-size="11" font-family="ui-monospace, monospace" fill="#0f172a" font-weight="600">Back-to-back N-channel — BMS 표준 (low-side)</text>
    <text x="14" y="34" font-size="10" font-family="ui-monospace, monospace" fill="#64748b">두 source 묶임 · body diode 가 서로 반대 방향 → 두 FET 모두 ON 일 때만 도통</text>

    <!-- =========== Battery (left) =========== -->
    <rect x="30" y="100" width="80" height="160" fill="#10b981" stroke="#047857" stroke-width="1.5" />
    <text x="58" y="180" font-size="11" fill="#fff" font-family="ui-monospace, monospace" font-weight="600">BAT</text>
    <text x="42" y="200" font-size="9" fill="#fff" font-family="ui-monospace, monospace">cells</text>
    <!-- B+ marker -->
    <text x="116" y="120" font-size="10" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">B+</text>
    <!-- B- marker -->
    <text x="116" y="248" font-size="10" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">B−</text>

    <!-- =========== Top wire: B+ direct to PACK+ =========== -->
    <line x1="110" y1="115" x2="610" y2="115" stroke="#0f172a" stroke-width="2" />

    <!-- =========== Bottom path: B- → Q1 → MID → Q2 → PACK- =========== -->
    <line x1="110" y1="245" x2="180" y2="245" stroke="#0f172a" stroke-width="2" />

    <!-- ========== Q1 — CHG FET (closer to B-) ========== -->
    <g>
      <!-- FET body box -->
      <rect x="180" y="220" width="100" height="70" fill="#fef3c7" stroke="#92400e" stroke-width="1.5" rx="2" />
      <text x="220" y="237" font-size="9" fill="#92400e" font-family="ui-monospace, monospace" font-weight="600">Q1 (CHG)</text>
      <text x="208" y="282" font-size="8" fill="#92400e" font-family="ui-monospace, monospace">N-channel</text>

      <!-- D pin (LEFT, outward toward B-) -->
      <text x="186" y="252" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">D</text>
      <!-- S pin (RIGHT, inward toward MID) -->
      <text x="266" y="252" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">S</text>
      <!-- Gate pin (top) -->
      <line x1="230" y1="220" x2="230" y2="195" stroke="#0f172a" stroke-width="1.5" />
      <text x="236" y="210" font-size="9" fill="#475569" font-family="ui-monospace, monospace">G</text>

      <!-- Body diode INSIDE box: anode at S (right), cathode at D (left), triangle pointing LEFT -->
      <!-- triangle: anode side at right (245), cathode apex at left (215) -->
      <polygon points="245,260 245,272 215,266" fill="#dc2626" stroke="#dc2626" stroke-width="1" />
      <!-- cathode bar (perpendicular to direction) at left -->
      <line x1="213" y1="258" x2="213" y2="274" stroke="#dc2626" stroke-width="1.8" />
      <!-- internal connection of diode to D pad and S pad (faint) -->
      <line x1="213" y1="266" x2="195" y2="266" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 1" />
      <line x1="245" y1="266" x2="265" y2="266" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 1" />
    </g>

    <!-- ========== MID node ========== -->
    <line x1="280" y1="245" x2="400" y2="245" stroke="#0f172a" stroke-width="2" />
    <circle cx="340" cy="245" r="3" fill="#0f172a" />
    <text x="320" y="232" font-size="10" fill="#4f46e5" font-family="ui-monospace, monospace" font-weight="600">MID</text>
    <text x="296" y="220" font-size="8" fill="#64748b" font-family="ui-monospace, monospace">(공통 source)</text>

    <!-- ========== Q2 — DSG FET (closer to PACK-) ========== -->
    <g>
      <rect x="400" y="220" width="100" height="70" fill="#fef3c7" stroke="#92400e" stroke-width="1.5" rx="2" />
      <text x="438" y="237" font-size="9" fill="#92400e" font-family="ui-monospace, monospace" font-weight="600">Q2 (DSG)</text>
      <text x="428" y="282" font-size="8" fill="#92400e" font-family="ui-monospace, monospace">N-channel</text>

      <!-- S pin (LEFT, inward toward MID) -->
      <text x="406" y="252" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">S</text>
      <!-- D pin (RIGHT, outward toward PACK-) -->
      <text x="486" y="252" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">D</text>
      <!-- Gate pin (top) -->
      <line x1="450" y1="220" x2="450" y2="195" stroke="#0f172a" stroke-width="1.5" />
      <text x="456" y="210" font-size="9" fill="#475569" font-family="ui-monospace, monospace">G</text>

      <!-- Body diode: anode at S (left, MID side), cathode at D (right, PACK- side), triangle pointing RIGHT -->
      <polygon points="435,260 435,272 465,266" fill="#dc2626" stroke="#dc2626" stroke-width="1" />
      <!-- cathode bar at right -->
      <line x1="467" y1="258" x2="467" y2="274" stroke="#dc2626" stroke-width="1.8" />
      <!-- internal dashed connections -->
      <line x1="415" y1="266" x2="435" y2="266" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 1" />
      <line x1="467" y1="266" x2="485" y2="266" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 1" />
    </g>

    <!-- Q2 → PACK- -->
    <line x1="500" y1="245" x2="610" y2="245" stroke="#0f172a" stroke-width="2" />

    <!-- ========== PACK connector (right) ========== -->
    <rect x="610" y="100" width="50" height="160" fill="#0f172a" stroke="#1e293b" />
    <text x="617" y="180" font-size="10" fill="#fff" font-family="ui-monospace, monospace" font-weight="600">PACK</text>
    <text x="617" y="195" font-size="8" fill="#cbd5e1" font-family="ui-monospace, monospace">load /</text>
    <text x="617" y="206" font-size="8" fill="#cbd5e1" font-family="ui-monospace, monospace">charger</text>
    <text x="588" y="113" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">PACK+</text>
    <text x="588" y="258" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">PACK−</text>

    <!-- ========== BMS IC (top) ========== -->
    <rect x="220" y="60" width="240" height="40" fill="#0f172a" stroke="#1e293b" />
    <text x="316" y="84" font-size="10" fill="#fff" font-family="ui-monospace, monospace" font-weight="600">BMS IC</text>

    <!-- Gate drives -->
    <line x1="260" y1="100" x2="260" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="260" y1="180" x2="230" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="230" y1="180" x2="230" y2="195" stroke="#1e40af" stroke-width="1.2" />
    <text x="262" y="135" font-size="8" fill="#1e40af" font-family="ui-monospace, monospace">CHG</text>

    <line x1="420" y1="100" x2="420" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="420" y1="180" x2="450" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="450" y1="180" x2="450" y2="195" stroke="#1e40af" stroke-width="1.2" />
    <text x="424" y="135" font-size="8" fill="#1e40af" font-family="ui-monospace, monospace">DSG</text>

    <!-- ========== Current direction arrows (educational) ========== -->
    <!-- Discharge: BAT+ → load → PACK- → Q2.D → Q2.S → MID → Q1.S → Q1.D → B- -->
    <g opacity="0.85">
      <!-- top: B+ to PACK+ direction (rightward) -->
      <polygon points="380,108 396,115 380,122" fill="#10b981" />
      <text x="320" y="105" font-size="9" fill="#047857" font-family="ui-monospace, monospace" font-weight="600">방전 (discharge) →</text>
      <!-- bottom: PACK- to B- (leftward through FETs) -->
      <polygon points="180,237 164,245 180,253" fill="#10b981" />
    </g>

    <!-- ========== Annotations ========== -->
    <g font-family="ui-monospace, monospace" font-size="9">
      <text x="14" y="318" fill="#0f172a" font-weight="600">동작:</text>
      <text x="60" y="318" fill="#475569">두 FET 모두 ON  →  양방향 도통 (정상)</text>
      <text x="60" y="332" fill="#475569"><tspan fill="#dc2626" font-weight="600">CHG OFF</tspan> (Q1)  →  충전 차단 (충전 시 전류는 B−→MID 방향, Q1 body diode 의 reverse 방향)</text>
      <text x="60" y="346" fill="#475569"><tspan fill="#dc2626" font-weight="600">DSG OFF</tspan> (Q2)  →  방전 차단 (방전 시 전류는 PACK−→MID 방향, Q2 body diode 의 reverse 방향)</text>
    </g>
  </svg>
</figure>
