---
// Back-to-back N-channel MOSFETs — low-side BMS, common-DRAIN topology.
// Two N-channel FETs with DRAINS tied at MID, sources pointing outward
// (B- and PACK-). Body diodes face INWARD (toward MID), so neither
// charge nor discharge can flow unless the corresponding FET is ON.
// (Common-source 변형도 가능 — sources tied at MID, body diode 바깥쪽.
// 두 토폴로지 모두 BMS 에서 사용됨; 차이는 게이트 드라이브 reference 와
// CHG/DSG 위치 swap 뿐.)
---
<figure class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <svg viewBox="0 0 680 420" class="w-full" role="img" aria-label="Back-to-back N-channel MOSFETs in a BMS — low-side common-drain topology with drains tied at MID and body diodes facing inward toward MID">
    <rect x="1" y="1" width="678" height="418" fill="#fff" stroke="#e2e8f0" />
    <text x="14" y="20" font-size="11" font-family="ui-monospace, monospace" fill="#0f172a" font-weight="600">Back-to-back N-channel — BMS (low-side, common-drain)</text>
    <text x="14" y="34" font-size="10" font-family="ui-monospace, monospace" fill="#64748b">표준 회로기호 · 두 drain 묶임 · body diode 가 서로 반대 방향(둘 다 MID 향함) → 두 FET 모두 ON 일 때만 도통</text>

    <!-- =========== Battery (left) =========== -->
    <rect x="30" y="100" width="80" height="160" fill="#10b981" stroke="#047857" stroke-width="1.5" />
    <text x="58" y="180" font-size="11" fill="#fff" font-family="ui-monospace, monospace" font-weight="600">BAT</text>
    <text x="42" y="200" font-size="9" fill="#fff" font-family="ui-monospace, monospace">cells</text>
    <text x="116" y="120" font-size="10" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">B+</text>
    <text x="116" y="248" font-size="10" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">B−</text>

    <!-- =========== Top wire: B+ direct to PACK+ =========== -->
    <line x1="110" y1="115" x2="610" y2="115" stroke="#0f172a" stroke-width="2" />

    <!-- =========== Bottom path: B- → Q1 → MID → Q2 → PACK- =========== -->
    <line x1="110" y1="245" x2="180" y2="245" stroke="#0f172a" stroke-width="2" />

    <!-- ========== BMS IC (top) ========== -->
    <rect x="220" y="60" width="240" height="40" fill="#0f172a" stroke="#1e293b" />
    <text x="316" y="84" font-size="10" fill="#fff" font-family="ui-monospace, monospace" font-weight="600">BMS IC</text>

    <!-- Gate drives — common-drain low-side: Q1=DSG, Q2=CHG -->
    <line x1="260" y1="100" x2="260" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="260" y1="180" x2="231" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="231" y1="180" x2="231" y2="200" stroke="#1e40af" stroke-width="1.2" />
    <text x="262" y="135" font-size="8" fill="#1e40af" font-family="ui-monospace, monospace">DSG</text>

    <line x1="420" y1="100" x2="420" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="420" y1="180" x2="449" y2="180" stroke="#1e40af" stroke-width="1.2" />
    <line x1="449" y1="180" x2="449" y2="200" stroke="#1e40af" stroke-width="1.2" />
    <text x="424" y="135" font-size="8" fill="#1e40af" font-family="ui-monospace, monospace">CHG</text>

    <!-- ========== Q1 — DSG FET (closer to B-, source LEFT, drain RIGHT toward MID) ========== -->
    <g>
      <!-- Source pin wire (entering from left rail at y=245, B- side) -->
      <line x1="180" y1="245" x2="210" y2="245" stroke="#0f172a" stroke-width="2" />
      <!-- Drain pin wire (exiting right toward MID) -->
      <line x1="252" y1="245" x2="285" y2="245" stroke="#0f172a" stroke-width="2" />
      <!-- Gate pin wire (from BMS IC at top) -->
      <line x1="231" y1="200" x2="231" y2="232" stroke="#0f172a" stroke-width="1.8" />

      <!-- Gate electrode bar (horizontal, the "G" plate, isolated by gap) -->
      <line x1="214" y1="232" x2="248" y2="232" stroke="#0f172a" stroke-width="2.5" />

      <!-- Channel: 3 disjoint horizontal segments at y=240 (broken = enhancement-mode) -->
      <line x1="214" y1="240" x2="222" y2="240" stroke="#0f172a" stroke-width="2.5" />
      <line x1="227" y1="240" x2="235" y2="240" stroke="#0f172a" stroke-width="2.5" />
      <line x1="240" y1="240" x2="248" y2="240" stroke="#0f172a" stroke-width="2.5" />

      <!-- Stubs from leftmost & rightmost channel segments down to S/D pin wires at y=245 -->
      <line x1="214" y1="240" x2="214" y2="245" stroke="#0f172a" stroke-width="1.5" />
      <line x1="248" y1="240" x2="248" y2="245" stroke="#0f172a" stroke-width="1.5" />
      <line x1="210" y1="245" x2="214" y2="245" stroke="#0f172a" stroke-width="1.5" />
      <line x1="248" y1="245" x2="252" y2="245" stroke="#0f172a" stroke-width="1.5" />

      <!-- Body/substrate arrow (N-channel: tip points UP toward channel) at middle segment -->
      <polygon points="231,240 227,247 235,247" fill="#0f172a" />

      <!-- Pin labels — common-drain: S on LEFT (toward B-), D on RIGHT (toward MID) -->
      <text x="187" y="240" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">S</text>
      <text x="270" y="240" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">D</text>
      <text x="237" y="218" font-size="9" fill="#475569" font-family="ui-monospace, monospace">G</text>

      <!-- FET label below -->
      <text x="195" y="278" font-size="10" fill="#92400e" font-family="ui-monospace, monospace" font-weight="600">Q1 (DSG)</text>
      <text x="208" y="291" font-size="8" fill="#92400e" font-family="ui-monospace, monospace">N-ch enh.</text>

      <!-- Body diode (parasitic) — anode at S (LEFT, B- side), cathode at D (RIGHT, MID side), triangle points RIGHT (toward MID) -->
      <line x1="210" y1="245" x2="210" y2="320" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 2" />
      <line x1="252" y1="245" x2="252" y2="320" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 2" />
      <line x1="210" y1="320" x2="216" y2="320" stroke="#dc2626" stroke-width="1.2" />
      <line x1="244" y1="320" x2="252" y2="320" stroke="#dc2626" stroke-width="1.2" />
      <!-- Triangle: anode at left (216,320) to cathode tip at right (242,320) -->
      <polygon points="216,313 216,327 242,320" fill="#dc2626" />
      <!-- Cathode bar (perpendicular) at right tip -->
      <line x1="244" y1="313" x2="244" y2="327" stroke="#dc2626" stroke-width="2" />
      <text x="200" y="343" font-size="8" fill="#dc2626" font-family="ui-monospace, monospace">body diode</text>
    </g>

    <!-- ========== MID node (common drain) ========== -->
    <line x1="285" y1="245" x2="395" y2="245" stroke="#0f172a" stroke-width="2" />
    <circle cx="340" cy="245" r="3" fill="#0f172a" />
    <text x="320" y="232" font-size="10" fill="#4f46e5" font-family="ui-monospace, monospace" font-weight="600">MID</text>
    <text x="296" y="220" font-size="8" fill="#64748b" font-family="ui-monospace, monospace">(공통 drain)</text>

    <!-- ========== Q2 — CHG FET (closer to PACK-, drain LEFT toward MID, source RIGHT) ========== -->
    <g>
      <!-- Drain pin wire (entering from left, MID side) -->
      <line x1="395" y1="245" x2="428" y2="245" stroke="#0f172a" stroke-width="2" />
      <!-- Source pin wire (exiting right toward PACK-) -->
      <line x1="470" y1="245" x2="500" y2="245" stroke="#0f172a" stroke-width="2" />
      <!-- Gate pin wire (from BMS IC) -->
      <line x1="449" y1="200" x2="449" y2="232" stroke="#0f172a" stroke-width="1.8" />

      <!-- Gate electrode bar -->
      <line x1="432" y1="232" x2="466" y2="232" stroke="#0f172a" stroke-width="2.5" />

      <!-- Channel: 3 disjoint horizontal segments at y=240 -->
      <line x1="432" y1="240" x2="440" y2="240" stroke="#0f172a" stroke-width="2.5" />
      <line x1="445" y1="240" x2="453" y2="240" stroke="#0f172a" stroke-width="2.5" />
      <line x1="458" y1="240" x2="466" y2="240" stroke="#0f172a" stroke-width="2.5" />

      <!-- D-rail (left, MID side) and S-rail (right, PACK- side) -->
      <line x1="432" y1="240" x2="432" y2="245" stroke="#0f172a" stroke-width="1.5" />
      <line x1="466" y1="240" x2="466" y2="245" stroke="#0f172a" stroke-width="1.5" />
      <line x1="428" y1="245" x2="432" y2="245" stroke="#0f172a" stroke-width="1.5" />
      <line x1="466" y1="245" x2="470" y2="245" stroke="#0f172a" stroke-width="1.5" />

      <!-- Body arrow (N-channel: tip UP toward channel) -->
      <polygon points="449,240 445,247 453,247" fill="#0f172a" />

      <!-- Pin labels — common-drain: D on LEFT (toward MID), S on RIGHT (toward PACK-) -->
      <text x="412" y="240" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">D</text>
      <text x="486" y="240" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">S</text>
      <text x="455" y="218" font-size="9" fill="#475569" font-family="ui-monospace, monospace">G</text>

      <!-- FET label -->
      <text x="413" y="278" font-size="10" fill="#92400e" font-family="ui-monospace, monospace" font-weight="600">Q2 (CHG)</text>
      <text x="427" y="291" font-size="8" fill="#92400e" font-family="ui-monospace, monospace">N-ch enh.</text>

      <!-- Body diode — anode at S (RIGHT, PACK- side), cathode at D (LEFT, MID side), triangle points LEFT (toward MID) -->
      <line x1="428" y1="245" x2="428" y2="320" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 2" />
      <line x1="470" y1="245" x2="470" y2="320" stroke="#dc2626" stroke-width="0.8" stroke-dasharray="2 2" />
      <line x1="428" y1="320" x2="436" y2="320" stroke="#dc2626" stroke-width="1.2" />
      <line x1="464" y1="320" x2="470" y2="320" stroke="#dc2626" stroke-width="1.2" />
      <!-- Triangle: anode at right (464,320), cathode tip at left (438,320) -->
      <polygon points="464,313 464,327 438,320" fill="#dc2626" />
      <!-- Cathode bar at left tip -->
      <line x1="436" y1="313" x2="436" y2="327" stroke="#dc2626" stroke-width="2" />
      <text x="425" y="343" font-size="8" fill="#dc2626" font-family="ui-monospace, monospace">body diode</text>
    </g>

    <!-- Q2 → PACK- -->
    <line x1="500" y1="245" x2="610" y2="245" stroke="#0f172a" stroke-width="2" />

    <!-- ========== PACK connector (right) ========== -->
    <rect x="610" y="100" width="50" height="160" fill="#0f172a" stroke="#1e293b" />
    <text x="617" y="180" font-size="10" fill="#fff" font-family="ui-monospace, monospace" font-weight="600">PACK</text>
    <text x="617" y="195" font-size="8" fill="#cbd5e1" font-family="ui-monospace, monospace">load /</text>
    <text x="617" y="206" font-size="8" fill="#cbd5e1" font-family="ui-monospace, monospace">charger</text>
    <text x="588" y="113" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">PACK+</text>
    <text x="588" y="258" font-size="9" fill="#0f172a" font-family="ui-monospace, monospace" font-weight="600">PACK−</text>

    <!-- ========== Current direction arrows (educational) ========== -->
    <g opacity="0.85">
      <polygon points="380,108 396,115 380,122" fill="#10b981" />
      <text x="320" y="105" font-size="9" fill="#047857" font-family="ui-monospace, monospace" font-weight="600">방전 (discharge) →</text>
      <polygon points="180,237 164,245 180,253" fill="#10b981" />
    </g>

    <!-- ========== Annotations ========== -->
    <g font-family="ui-monospace, monospace" font-size="9">
      <text x="14" y="368" fill="#0f172a" font-weight="600">동작:</text>
      <text x="60" y="368" fill="#475569">두 FET 모두 ON  →  양방향 도통 (정상)</text>
      <text x="60" y="383" fill="#475569"><tspan fill="#dc2626" font-weight="600">DSG OFF</tspan> (Q1)  →  방전 차단 (방전 시 전류는 MID→B− 방향, Q1 body diode 의 reverse 방향)</text>
      <text x="60" y="398" fill="#475569"><tspan fill="#dc2626" font-weight="600">CHG OFF</tspan> (Q2)  →  충전 차단 (충전 시 전류는 MID→PACK− 방향, Q2 body diode 의 reverse 방향)</text>
    </g>
  </svg>
</figure>
