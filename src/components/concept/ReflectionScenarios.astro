---
// Three side-by-side mini bounce diagrams for matched / open / short load,
// with the resulting V_load waveform sketched beneath each.
const scenarios = [
  { label: 'Matched  (Z_L = Z₀)', gL:  0,   tint: 'emerald', note: '반사 없음 — 깨끗한 스텝' },
  { label: 'Open     (Z_L = ∞)',   gL:  1,   tint: 'rose',    note: '전파 반사 · 양방향 배수' },
  { label: 'Short    (Z_L = 0)',   gL: -1,   tint: 'amber',   note: '반전 반사 · 로드 전압 0' },
];

function tintBg(t: string)    { return ({ emerald: 'bg-emerald-50', rose: 'bg-rose-50',    amber: 'bg-amber-50'    } as any)[t]; }
function tintBorder(t: string){ return ({ emerald: 'border-emerald-200', rose: 'border-rose-200', amber: 'border-amber-200' } as any)[t]; }
function tintText(t: string)  { return ({ emerald: '#065f46', rose: '#9f1239', amber: '#92400e' } as any)[t]; }
function tintTrace(t: string) { return ({ emerald: '#059669', rose: '#e11d48', amber: '#d97706' } as any)[t]; }
---
<div class="not-prose grid gap-3 md:grid-cols-3">
  {scenarios.map((s) => {
    const vIncident = 0.5;          // Vs/2 assuming matched source
    const vReflected = s.gL * vIncident;
    const vLoadFinal = vIncident * (1 + s.gL);
    return (
      <figure class={`rounded-lg border p-3 ${tintBorder(s.tint)} ${tintBg(s.tint)}`}>
        <div class="font-mono text-xs" style={`color: ${tintText(s.tint)}`}>{s.label}</div>
        <svg viewBox="0 0 240 160" class="mt-2 w-full">
          <rect x="1" y="1" width="238" height="158" fill="#ffffff" stroke="#e2e8f0" />

          <!-- Source/line/load sketch -->
          <rect x="10" y="15" width="24" height="18" fill="#0f172a" />
          <line x1="34" y1="24" x2="200" y2="24" stroke="#334155" stroke-width="2" />
          <rect x="200" y="15" width="24" height="18" fill="#0f172a" />
          <text x="60" y="18" font-size="8" fill="#64748b" font-family="ui-monospace, monospace">Z₀ = 50 Ω</text>

          <!-- Incident wave arrow -->
          <path d="M 50 30 L 100 30" stroke="#4f46e5" stroke-width="1.5" marker-end="url(#ar1)" />
          <text x="52" y="26" font-size="7" fill="#4f46e5" font-family="ui-monospace, monospace">V⁺</text>

          <!-- Reflected wave arrow (scaled) -->
          {s.gL !== 0 && (
            <g>
              <path d="M 180 40 L 140 40" stroke={tintTrace(s.tint)} stroke-width="1.5" marker-end="url(#ar1)" />
              <text x="145" y="36" font-size="7" fill={tintTrace(s.tint)} font-family="ui-monospace, monospace">V⁻ = {s.gL > 0 ? '+' : ''}{s.gL.toFixed(0)}·V⁺</text>
            </g>
          )}

          <!-- V_load waveform sketch, time axis -->
          <line x1="20" y1="130" x2="220" y2="130" stroke="#94a3b8" stroke-width="0.8" />
          <line x1="20" y1="70"  x2="20"  y2="140" stroke="#94a3b8" stroke-width="0.8" />
          <text x="6" y="75" font-size="7" fill="#94a3b8" font-family="ui-monospace, monospace">V_L</text>
          <text x="205" y="145" font-size="7" fill="#94a3b8" font-family="ui-monospace, monospace">t</text>

          <!-- Waveform -->
          { s.gL === 0 && (
            <path d={`M 20 130 L 80 130 L 80 100 L 220 100`} stroke={tintTrace(s.tint)} stroke-width="1.8" fill="none" />
          )}
          { s.gL === 1 && (
            <path d={`M 20 130 L 80 130 L 80 80 L 220 80`} stroke={tintTrace(s.tint)} stroke-width="1.8" fill="none" />
          )}
          { s.gL === -1 && (
            <path d={`M 20 130 L 220 130`} stroke={tintTrace(s.tint)} stroke-width="1.8" fill="none" />
          )}

          <!-- final load voltage label -->
          <text x="130" y="95" font-size="8" fill={tintTrace(s.tint)} font-family="ui-monospace, monospace">
            V_L = (1 + {s.gL.toFixed(0)})·V⁺ = {vLoadFinal.toFixed(1)}·V⁺
          </text>

          <defs>
            <marker id="ar1" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="5" markerHeight="5" orient="auto-start-reverse">
              <path d="M 0 0 L 10 5 L 0 10 z" fill="currentColor" />
            </marker>
          </defs>
        </svg>
        <figcaption class="mt-1 text-[11px] text-slate-700">{s.note}</figcaption>
      </figure>
    );
  })}
</div>
