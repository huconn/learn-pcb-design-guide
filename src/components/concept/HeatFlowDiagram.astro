---
// Heat flow path: Junction → Case → Board → Ambient, with theta annotations
---
<figure class="not-prose rounded-lg border border-slate-200 bg-white p-4">
  <svg viewBox="0 0 540 220" class="w-full" role="img" aria-label="Heat flow path from junction to ambient via theta resistances">
    <rect x="1" y="1" width="538" height="218" fill="#fff" stroke="#e2e8f0" />
    <text x="14" y="20" font-size="11" font-family="ui-monospace, monospace" fill="#0f172a">열 흐름 경로 — junction에서 ambient 까지</text>

    <!-- Junction (silicon die) -->
    <rect x="40" y="80" width="60" height="60" fill="#dc2626" stroke="#7f1d1d" />
    <text x="48" y="105" font-size="10" fill="#fff" font-family="ui-monospace, monospace">die</text>
    <text x="46" y="120" font-size="9" fill="#fff" font-family="ui-monospace, monospace">T_j</text>
    <text x="40" y="160" font-size="9" fill="#7f1d1d" font-family="ui-monospace, monospace">Junction</text>

    <!-- theta_jc -->
    <line x1="100" y1="110" x2="160" y2="110" stroke="#0f172a" stroke-width="2" marker-end="url(#arrow1)" />
    <text x="105" y="100" font-size="10" fill="#475569" font-family="ui-monospace, monospace">θ_jc</text>

    <!-- Case (package) -->
    <rect x="160" y="80" width="60" height="60" fill="#fbbf24" stroke="#92400e" />
    <text x="172" y="115" font-size="10" fill="#92400e" font-family="ui-monospace, monospace">case</text>
    <text x="160" y="160" font-size="9" fill="#92400e" font-family="ui-monospace, monospace">패키지</text>

    <!-- theta_cb -->
    <line x1="220" y1="110" x2="280" y2="110" stroke="#0f172a" stroke-width="2" marker-end="url(#arrow1)" />
    <text x="225" y="100" font-size="10" fill="#475569" font-family="ui-monospace, monospace">θ_cb</text>

    <!-- Board (PCB) -->
    <rect x="280" y="80" width="80" height="60" fill="#10b981" stroke="#047857" />
    <text x="295" y="115" font-size="10" fill="#fff" font-family="ui-monospace, monospace">board</text>
    <text x="295" y="160" font-size="9" fill="#047857" font-family="ui-monospace, monospace">PCB plane</text>

    <!-- theta_ba -->
    <line x1="360" y1="110" x2="420" y2="110" stroke="#0f172a" stroke-width="2" marker-end="url(#arrow1)" />
    <text x="365" y="100" font-size="10" fill="#475569" font-family="ui-monospace, monospace">θ_ba</text>

    <!-- Ambient -->
    <rect x="420" y="80" width="80" height="60" fill="#94a3b8" stroke="#475569" />
    <text x="438" y="115" font-size="10" fill="#fff" font-family="ui-monospace, monospace">ambient</text>
    <text x="430" y="160" font-size="9" fill="#475569" font-family="ui-monospace, monospace">T_a (공기)</text>

    <!-- Combined θ_JA -->
    <path d="M 70 200 Q 200 200 460 200" fill="none" stroke="#4f46e5" stroke-width="1.5" stroke-dasharray="4 3" />
    <text x="200" y="195" font-size="10" fill="#4f46e5" font-family="ui-monospace, monospace" font-weight="600">θ_JA = θ_jc + θ_cb + θ_ba (시리즈 합)</text>

    <text x="14" y="40" font-size="10" fill="#475569" font-family="ui-monospace, monospace">T_j = T_a + θ_JA × P_dissipation</text>

    <defs>
      <marker id="arrow1" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
        <path d="M 0 0 L 10 5 L 0 10 z" fill="#0f172a" />
      </marker>
    </defs>
  </svg>
</figure>
