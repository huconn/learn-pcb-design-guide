---
import { FAB_TIERS } from '../../lib/dfm/fabClasses';

const tiers = FAB_TIERS;
const tints = ['emerald', 'sky', 'indigo', 'rose'] as const;
const toneClasses: Record<string, { bg: string; border: string; text: string; chip: string }> = {
  emerald: { bg: 'bg-emerald-50', border: 'border-emerald-200', text: 'text-emerald-900', chip: 'bg-emerald-100 text-emerald-800' },
  sky:     { bg: 'bg-sky-50',     border: 'border-sky-200',     text: 'text-sky-900',     chip: 'bg-sky-100 text-sky-800' },
  indigo:  { bg: 'bg-indigo-50',  border: 'border-indigo-200',  text: 'text-indigo-900',  chip: 'bg-indigo-100 text-indigo-800' },
  rose:    { bg: 'bg-rose-50',    border: 'border-rose-200',    text: 'text-rose-900',    chip: 'bg-rose-100 text-rose-800' },
};
---
<div class="not-prose overflow-x-auto rounded-lg border border-slate-200">
  <table class="w-full border-collapse text-sm">
    <thead class="bg-slate-50 text-slate-600 font-mono text-[10px] tracking-widest uppercase">
      <tr>
        <th class="text-left px-3 py-2 border-b border-slate-200">Tier</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Vendor 예시</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">비용</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Trace</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Spacing</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Drill</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Annular</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Layers</th>
        <th class="text-left px-3 py-2 border-b border-slate-200">Via</th>
      </tr>
    </thead>
    <tbody>
      {tiers.map((t, i) => {
        const c = toneClasses[tints[i % tints.length]];
        return (
          <tr class={c.bg + ' ' + c.text}>
            <td class={'px-3 py-2 border-b ' + c.border + ' font-medium align-top'}>
              <div>{t.name}</div>
              <div class="font-mono text-[11px] text-slate-500 mt-0.5">{t.description}</div>
            </td>
            <td class={'px-3 py-2 border-b ' + c.border + ' text-[12px] align-top'}>{t.vendor}</td>
            <td class={'px-3 py-2 border-b ' + c.border + ' align-top'}>
              <span class={'inline-block rounded px-1.5 py-0.5 font-mono text-[11px] ' + c.chip}>{t.costFactor}</span>
            </td>
            <td class={'px-3 py-2 border-b ' + c.border + ' font-mono text-[12px] align-top'}>{t.trace} mil</td>
            <td class={'px-3 py-2 border-b ' + c.border + ' font-mono text-[12px] align-top'}>{t.spacing} mil</td>
            <td class={'px-3 py-2 border-b ' + c.border + ' font-mono text-[12px] align-top'}>{t.drill} mm</td>
            <td class={'px-3 py-2 border-b ' + c.border + ' font-mono text-[12px] align-top'}>{t.annularRing} mil</td>
            <td class={'px-3 py-2 border-b ' + c.border + ' font-mono text-[12px] align-top'}>{t.layers}</td>
            <td class={'px-3 py-2 border-b ' + c.border + ' text-[11px] align-top leading-snug'}>{t.via}</td>
          </tr>
        );
      })}
    </tbody>
  </table>
</div>
<p class="mt-2 text-xs text-slate-500">
  ※ 위 값은 <b>전형적 가이드</b> — 정확한 값은 fab 의 capability 시트를 참조. 가격은 동일 보드 기준 상대값.
</p>
