---
interface Props { label?: string }
const { label = '개념 다이어그램 보기 (비유 · 회로 · 주파수 대역)' } = Astro.props;
---
<details class="my-6 rounded-xl border border-slate-200 bg-slate-50/60 px-5 py-4">
  <summary class="cursor-pointer select-none font-medium text-slate-700 hover:text-slate-900 list-none flex items-center justify-between">
    <span class="flex items-center gap-2">
      <span class="font-mono text-[10px] tracking-widest text-slate-500 uppercase">Concept</span>
      {label}
    </span>
    <span class="text-slate-400 text-sm">▼</span>
  </summary>
  <div class="mt-4 space-y-6">
    <slot />
  </div>
</details>
