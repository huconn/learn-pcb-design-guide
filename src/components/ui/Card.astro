---
interface Props {
  title?: string;
  subtitle?: string;
  id?: string;
  class?: string;
}
const { title, subtitle, id, class: className = '' } = Astro.props;
---
<section id={id} class={"rounded-xl border border-slate-200 bg-white p-5 sm:p-6 scroll-mt-20 " + className}>
  {(title || subtitle) && (
    <header class="mb-4">
      {title && <h2 class="text-lg font-semibold text-slate-900">{title}</h2>}
      {subtitle && <p class="mt-1 text-sm text-slate-600">{subtitle}</p>}
    </header>
  )}
  <slot />
</section>
