---
// Pagefind-backed search. Lightweight custom UI on top of the pagefind
// core JS API (instead of the prebuilt PagefindUI widget) to match the
// site's Tailwind styling.
---
<div class="relative">
  <button
    type="button"
    id="search-open"
    aria-label="검색 열기"
    class="w-full flex items-center justify-between gap-2 rounded-md border border-slate-200 bg-white px-3 py-1.5 text-left text-sm text-slate-500 hover:border-slate-300 hover:text-slate-700 transition"
  >
    <span class="flex items-center gap-2 min-w-0">
      <svg viewBox="0 0 24 24" class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="21" y1="21" x2="16.5" y2="16.5" />
      </svg>
      <span class="truncate">검색…</span>
    </span>
    <kbd class="font-mono text-[10px] text-slate-400 border border-slate-200 rounded px-1 py-0.5 hidden sm:inline">⌘K</kbd>
  </button>
</div>

<!-- Modal -->
<div
  id="search-modal"
  class="fixed inset-0 z-50 hidden items-start justify-center px-4 pt-16 sm:pt-24"
  role="dialog"
  aria-modal="true"
  aria-label="검색"
>
  <div id="search-backdrop" class="absolute inset-0 bg-slate-900/50"></div>
  <div class="relative w-full max-w-2xl rounded-xl border border-slate-200 bg-white shadow-2xl overflow-hidden flex flex-col" style="max-height: calc(100vh - 8rem);">
    <div class="flex items-center gap-3 px-4 py-3 border-b border-slate-200">
      <svg viewBox="0 0 24 24" class="w-5 h-5 shrink-0 text-slate-400" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="11" cy="11" r="7" />
        <line x1="21" y1="21" x2="16.5" y2="16.5" />
      </svg>
      <input
        type="search"
        id="search-input"
        placeholder="검색어 입력 — 트레이스, 디커플링, 임피던스…"
        autocomplete="off"
        class="flex-1 bg-transparent border-0 outline-none text-slate-900 placeholder:text-slate-400 text-sm"
      />
      <button type="button" id="search-close" aria-label="닫기" class="text-slate-400 hover:text-slate-700 text-xs font-mono px-2 py-0.5 border border-slate-200 rounded">ESC</button>
    </div>
    <div id="search-results" class="flex-1 overflow-y-auto px-2 py-2 text-sm">
      <div class="px-3 py-8 text-center text-slate-400 text-xs">검색어를 입력하세요</div>
    </div>
  </div>
</div>

<script is:inline>
  // Pagefind index is generated by the `pagefind --site dist` build step.
  // Loaded as a runtime module from the deployed static path. is:inline
  // prevents Vite from trying to resolve the path at build time.
  let pagefind = null;

  async function loadPagefind() {
    if (pagefind) return pagefind;
    try {
      pagefind = await import('/pcb/pagefind/pagefind.js');
      return pagefind;
    } catch (e) {
      console.error('Pagefind index not found. Did you run `npm run build`?', e);
      return null;
    }
  }

  const openBtn = document.getElementById('search-open');
  const modal = document.getElementById('search-modal');
  const backdrop = document.getElementById('search-backdrop');
  const closeBtn = document.getElementById('search-close');
  const input = document.getElementById('search-input');
  const resultsEl = document.getElementById('search-results');

  function openModal() {
    if (!modal || !input) return;
    modal.classList.remove('hidden');
    modal.classList.add('flex');
    document.body.style.overflow = 'hidden';
    setTimeout(() => input.focus(), 50);
    loadPagefind();
  }
  function closeModal() {
    if (!modal) return;
    modal.classList.add('hidden');
    modal.classList.remove('flex');
    document.body.style.overflow = '';
    if (input) input.value = '';
    if (resultsEl) resultsEl.innerHTML = '<div class="px-3 py-8 text-center text-slate-400 text-xs">검색어를 입력하세요</div>';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
      e.preventDefault();
      openModal();
    }
    if (e.key === 'Escape' && modal && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  let searchTimer: number | undefined;
  input?.addEventListener('input', () => {
    if (searchTimer) clearTimeout(searchTimer);
    searchTimer = window.setTimeout(runSearch, 100);
  });

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' } as Record<string, string>)[c] || c
    );
  }

  async function runSearch() {
    if (!input || !resultsEl) return;
    const q = input.value.trim();
    if (q.length < 2) {
      resultsEl.innerHTML = '<div class="px-3 py-8 text-center text-slate-400 text-xs">2자 이상 입력하세요</div>';
      return;
    }
    const pf = await loadPagefind();
    if (!pf) {
      resultsEl.innerHTML = '<div class="px-3 py-8 text-center text-rose-500 text-xs">검색 인덱스 로드 실패</div>';
      return;
    }
    const search = await pf.search(q);
    if (search.results.length === 0) {
      resultsEl.innerHTML = `<div class="px-3 py-8 text-center text-slate-400 text-xs">"${escapeHtml(q)}" 에 대한 결과 없음</div>`;
      return;
    }
    const top = search.results.slice(0, 8);
    const data = await Promise.all(top.map((r) => r.data()));
    resultsEl.innerHTML = data
      .map(
        (d) => `
        <a href="${escapeHtml(d.url)}" class="block rounded-md px-3 py-2 hover:bg-indigo-50 group">
          <div class="font-medium text-slate-900 group-hover:text-indigo-700 truncate">${escapeHtml(d.meta?.title || d.url)}</div>
          <div class="mt-0.5 text-[12px] text-slate-500 line-clamp-2">${d.excerpt}</div>
          <div class="mt-1 font-mono text-[10px] text-slate-400">${escapeHtml(d.url)}</div>
        </a>
      `,
      )
      .join('');
  }
</script>
