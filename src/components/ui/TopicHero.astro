---
import type { Topic } from '../../lib/content/topics';
import HeroBodePlot from '../sim/HeroBodePlot.svelte';

interface Props { topic: Topic }
const { topic } = Astro.props;
---
<section class="mt-2 mb-8 grid gap-6 lg:grid-cols-[1.1fr_1fr] lg:items-center">
  <div>
    <div class="font-mono text-[11px] tracking-widest text-indigo-600">{topic.category}</div>
    <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900">
      {topic.title}
      <span class="block mt-1 text-slate-500 text-xl font-normal">Design Guide</span>
    </h1>
    <p class="mt-4 max-w-xl text-slate-600 leading-relaxed">{topic.subtitle}</p>
    <div class="mt-5 flex flex-wrap gap-2 font-mono text-[11px]">
      <span class="rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-700">⏱ {topic.readingMinutes}분 읽기</span>
      <span class="rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-700">★ {topic.level}</span>
      <span class="rounded-md border border-indigo-200 bg-indigo-50 px-2 py-1 text-indigo-700">v0.1 · interactive</span>
    </div>
  </div>
  <div class="rounded-xl border border-slate-200 bg-slate-50 p-3">
    <div class="mb-2 flex items-baseline justify-between">
      <span class="font-mono text-[10px] tracking-widest text-slate-500">IMPEDANCE vs FREQUENCY · preset: recommended</span>
      <span class="font-mono text-[10px] text-slate-500">log–log</span>
    </div>
    <div class="h-[240px]">
      <HeroBodePlot client:load />
    </div>
    <div class="mt-2 flex gap-3 font-mono text-[10px] text-slate-500">
      <span class="flex items-center gap-1"><span class="block h-2 w-4 rounded-sm" style="background:#4f46e5"></span>권장 조합</span>
      <span class="flex items-center gap-1"><span class="block h-2 w-4 rounded-sm border-b-2 border-dashed border-rose-500"></span>100nF만</span>
      <span class="flex items-center gap-1"><span class="block h-0.5 w-4 bg-emerald-600"></span>타겟 50 mΩ</span>
    </div>
  </div>
</section>
