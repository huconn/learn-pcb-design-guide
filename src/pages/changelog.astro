---
import '../styles/global.css';
import Sidebar from '../components/ui/Sidebar.astro';
import { RELEASES, SITE_VERSION } from '../lib/version';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/pcb/favicon.svg" />
    <title>Changelog · PCB Design Guide</title>
    <meta name="description" content="PCB Design Guide 사이트의 버전별 변경 내역" />
    <meta name="author" content="hulryung" />
  </head>
  <body class="bg-white text-slate-900 antialiased">
    <Sidebar />
    <div class="lg:pl-64">
      <main class="mx-auto w-full max-w-4xl px-5 sm:px-8 py-8" data-pagefind-body>
        <section class="mt-2 mb-8">
          <div class="font-mono text-[11px] tracking-widest text-indigo-600">SITE · VERSIONING</div>
          <h1 class="mt-3 text-3xl sm:text-4xl font-semibold tracking-tight text-slate-900">
            Changelog
            <span class="block mt-1 text-slate-500 text-xl font-normal">버전별 변경 내역 — 현재 v{SITE_VERSION}</span>
          </h1>
          <p class="mt-4 max-w-2xl text-slate-600 leading-relaxed">
            형식은 <a href="https://keepachangelog.com/" target="_blank" rel="noopener noreferrer" class="text-indigo-600 underline decoration-indigo-200 hover:decoration-indigo-600">Keep a Changelog</a> · 버전은 <a href="https://semver.org/" target="_blank" rel="noopener noreferrer" class="text-indigo-600 underline decoration-indigo-200 hover:decoration-indigo-600">SemVer</a>. 1.0 이전 단계라 minor (가운데 숫자) 가 신규 토픽 / UX 변경, patch (마지막 숫자) 가 버그 수정 / 이미지 교체 / 문구 손질.
          </p>
          <div class="mt-4 flex flex-wrap gap-2 font-mono text-[11px]">
            <span class="rounded-md border border-indigo-200 bg-indigo-50 px-2 py-1 text-indigo-700">최신 v{SITE_VERSION}</span>
            <span class="rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-700">{RELEASES.length} releases</span>
            <a href="https://github.com/anthropics/claude-code/issues" target="_blank" rel="noopener noreferrer" class="rounded-md border border-slate-200 bg-white px-2 py-1 text-slate-700 hover:border-slate-300">CHANGELOG.md (repo)</a>
          </div>
        </section>

        <ol class="space-y-8">
          {RELEASES.map((r, i) => (
            <li class="relative pl-6">
              <span class={'absolute left-0 top-2 w-3 h-3 rounded-full ' + (i === 0 ? 'bg-indigo-500 ring-4 ring-indigo-100' : 'bg-slate-300')}></span>
              <article class={'rounded-xl border ' + (i === 0 ? 'border-indigo-200 bg-indigo-50/30' : 'border-slate-200 bg-white') + ' p-5'}>
                <header class="flex flex-wrap items-baseline justify-between gap-3 mb-3">
                  <h2 class="text-xl font-semibold text-slate-900 font-mono">v{r.version}</h2>
                  <time class="font-mono text-xs text-slate-500" datetime={r.date}>{r.date}</time>
                </header>
                {r.notes && (
                  <p class="text-sm text-slate-700 mb-4 leading-relaxed">{r.notes}</p>
                )}
                {r.added && r.added.length > 0 && (
                  <div class="mb-3">
                    <div class="font-mono text-[10px] tracking-widest uppercase text-emerald-700 mb-1">Added</div>
                    <ul class="list-disc pl-5 space-y-1 text-sm text-slate-700">
                      {r.added.map((a) => <li set:html={a.replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')}></li>)}
                    </ul>
                  </div>
                )}
                {r.changed && r.changed.length > 0 && (
                  <div class="mb-3">
                    <div class="font-mono text-[10px] tracking-widest uppercase text-amber-700 mb-1">Changed</div>
                    <ul class="list-disc pl-5 space-y-1 text-sm text-slate-700">
                      {r.changed.map((c) => <li set:html={c.replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')}></li>)}
                    </ul>
                  </div>
                )}
                {r.fixed && r.fixed.length > 0 && (
                  <div>
                    <div class="font-mono text-[10px] tracking-widest uppercase text-sky-700 mb-1">Fixed</div>
                    <ul class="list-disc pl-5 space-y-1 text-sm text-slate-700">
                      {r.fixed.map((f) => <li set:html={f.replace(/\*\*(.+?)\*\*/g, '<b>$1</b>')}></li>)}
                    </ul>
                  </div>
                )}
              </article>
            </li>
          ))}
        </ol>

        <section class="mt-10 rounded-lg border border-slate-200 bg-slate-50 p-5 text-sm text-slate-600 leading-relaxed">
          <h3 class="font-semibold text-slate-900 mb-2">버전 정책</h3>
          <ul class="list-disc pl-5 space-y-1">
            <li><b>major (1, 2, …)</b> — 사이트의 큰 구조 변경 (1.0 미만은 unreleased 취급)</li>
            <li><b>minor</b> — 신규 토픽 추가 또는 사용자에게 보이는 큰 UX 변경</li>
            <li><b>patch</b> — 버그 수정, 이미지 교체, 문구 손질, 작은 컴포넌트 변경</li>
          </ul>
          <p class="mt-3">
            새 버전은 GitHub release 와 동시에 이 페이지의 가장 위에 추가됩니다. 모든 페이지 footer 의 <span class="font-mono">v{SITE_VERSION}</span> 배지를 클릭하면 이 페이지로 이동합니다.
          </p>
        </section>
      </main>
      <footer class="border-t border-slate-200 mt-16">
        <div class="mx-auto max-w-6xl px-5 sm:px-8 py-6 text-xs text-slate-500 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <span>
              © <a href="https://x.com/hulryung" target="_blank" rel="noopener noreferrer" class="font-medium text-slate-700 hover:text-indigo-700">hulryung</a>
            </span>
            <span class="text-slate-300" aria-hidden="true">·</span>
            <a href="mailto:hulryung@gmail.com" class="hover:text-indigo-700">hulryung@gmail.com</a>
            <span class="text-slate-300" aria-hidden="true">·</span>
            <a href="https://x.com/hulryung" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-700">x.com/hulryung</a>
          </div>
          <a href="/pcb/changelog" class="font-mono text-indigo-600 hover:text-indigo-800">v{SITE_VERSION}</a>
        </div>
      </footer>
    </div>
  </body>
</html>
