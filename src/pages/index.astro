---
import '../styles/global.css';
import Sidebar from '../components/ui/Sidebar.astro';
import { TOPICS } from '../lib/content/topics';
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>PCB Design Guide · 인터랙티브 하드웨어 설계 가이드</title>
    <meta name="description" content="주니어 HW 엔지니어와 SW/FW 개발자를 위한 인터랙티브 PCB 설계 가이드 — 디커플링, 임피던스 매칭, 트레이스 기하, 고속 인터페이스, PDN, ESD 등 11개 토픽." />
    <meta name="author" content="hulryung" />
  </head>
  <body class="bg-white text-slate-900">
    <Sidebar />
    <div class="lg:pl-64">
      <main class="mx-auto max-w-6xl px-5 sm:px-8 py-16" data-pagefind-body>
        <div class="font-mono text-xs tracking-widest text-indigo-600">HARDWARE · PCB · GUIDE</div>
        <h1 class="mt-3 text-4xl sm:text-5xl font-semibold tracking-tight">인터랙티브 하드웨어 설계 가이드</h1>
        <p class="mt-4 max-w-2xl text-slate-600 leading-relaxed">
          주니어 HW 엔지니어와 SW/FW 개발자를 위한 회로 설계 리뷰 가이드. 개념 · 시뮬레이션 · 실측의 3단 접근으로 직관과 체험을 모두.
        </p>

        <ul class="mt-12 grid gap-4 sm:grid-cols-2">
          {TOPICS.map((t) => (
            <li>
              <a href={t.subpages && t.subpages.length ? t.subpages[0].href : `/${t.slug}`} class="block rounded-lg border border-slate-200 p-5 hover:border-indigo-300 hover:shadow-sm transition">
                <div class="font-mono text-[11px] tracking-widest text-indigo-600">{t.category}</div>
                <div class="mt-2 text-lg font-semibold text-slate-900">{t.title}</div>
                <div class="mt-1 text-sm text-slate-600">{t.subtitle}</div>
                <div class="mt-3 flex gap-2 font-mono text-[10px] text-slate-500">
                  <span class="rounded bg-slate-100 px-1.5 py-0.5 text-slate-700">⏱ {t.readingMinutes}분</span>
                  <span class="rounded bg-indigo-50 px-1.5 py-0.5 text-indigo-700">★ {t.level}</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </main>
      <footer class="border-t border-slate-200 mt-16">
        <div class="mx-auto max-w-6xl px-5 sm:px-8 py-6 text-xs text-slate-500 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <span>
              © <a href="https://x.com/hulryung" target="_blank" rel="noopener noreferrer" class="font-medium text-slate-700 hover:text-indigo-700">hulryung</a>
            </span>
            <span class="text-slate-300" aria-hidden="true">·</span>
            <a href="mailto:hulryung@gmail.com" class="hover:text-indigo-700">hulryung@gmail.com</a>
            <span class="text-slate-300" aria-hidden="true">·</span>
            <a href="https://x.com/hulryung" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-700">x.com/hulryung</a>
          </div>
          <span class="font-mono">v0.1</span>
        </div>
      </footer>
    </div>
  </body>
</html>
