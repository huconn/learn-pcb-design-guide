---
import '../styles/global.css';
import type { Topic } from '../lib/content/topics';
import Sidebar from '../components/ui/Sidebar.astro';
import { SITE_VERSION } from '../lib/version';

interface Props { topic: Topic; activeSubSlug?: string }
const { topic, activeSubSlug } = Astro.props;
---
<!doctype html>
<html lang="ko">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{topic.title} · PCB Design Guide</title>
    <meta name="description" content={topic.subtitle} />
    <meta name="author" content="hulryung" />
  </head>
  <body class="bg-white text-slate-900 antialiased">
    <Sidebar activeSlug={topic.slug} activeSubSlug={activeSubSlug} />
    <div class="lg:pl-64">
      <main class="mx-auto w-full max-w-6xl px-5 sm:px-8 py-8" data-pagefind-body>
        <slot />
      </main>
      <footer class="border-t border-slate-200 mt-16">
        <div class="mx-auto max-w-6xl px-5 sm:px-8 py-6 text-xs text-slate-500 flex flex-wrap items-center justify-between gap-x-4 gap-y-2">
          <div class="flex flex-wrap items-center gap-x-3 gap-y-1">
            <span>
              © <a href="https://x.com/hulryung" target="_blank" rel="noopener noreferrer" class="font-medium text-slate-700 hover:text-indigo-700">hulryung</a>
            </span>
            <span class="text-slate-300" aria-hidden="true">·</span>
            <a href="mailto:hulryung@gmail.com" class="hover:text-indigo-700">hulryung@gmail.com</a>
            <span class="text-slate-300" aria-hidden="true">·</span>
            <a href="https://x.com/hulryung" target="_blank" rel="noopener noreferrer" class="hover:text-indigo-700">x.com/hulryung</a>
          </div>
          <a href="/changelog" class="font-mono text-slate-500 hover:text-indigo-700" title="Changelog">v{SITE_VERSION}</a>
        </div>
      </footer>
    </div>
  </body>
</html>
